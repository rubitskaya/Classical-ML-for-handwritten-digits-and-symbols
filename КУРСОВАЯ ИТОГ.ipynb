    "# 10. Эксперименты с порядком предобработки и понижением размерности"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "81decb80",
   "metadata": {},
   "source": [
    "Рассмотрим как порядок шагов влияет на качество модели. Рассматрим следующие конфигурации:\n",
    "\n",
    "1. Baseline: нормализация -> удаление константных -> PCA(95%) -> kNN\n",
    "2. Без нормализации: удаление константных -> PCA(95%) -> kNN\n",
    "3. PCA до нормализации: PCA(95%) -> нормализация -> kNN\n",
    "4. PCA(80%): нормализация -> PCA(80%) -> kNN\n",
    "5. PCA(99%): нормализация -> PCA(99%) -> kNN"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 88,
   "id": "88488ed9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "                 Конфигурация  Accuracy  Компонент  Время (с)\n",
      "                      PCA 80%    0.8086         38        0.0\n",
      "Baseline (norm->const->PCA95)    0.7987        113        0.1\n",
      "             Без нормализации    0.7987        113        0.1\n",
      "                      PCA 99%    0.7922        276        0.1\n",
      "          PCA до нормализации    0.7303        113        0.0\n"
     ]
    }
   ],
   "source": [
    "configs = []\n",
    "\n",
    "def eval_knn(X_tr_, X_te_, y_tr_, y_te_, knn_params, label):\n",
    "    knn_ = KNeighborsClassifier(**knn_params, n_jobs=-1)\n",
    "    t0 = time.time()\n",
    "    knn_.fit(X_tr_, y_tr_)\n",
    "    t1 = time.time()\n",
    "    acc = accuracy_score(y_te_, knn_.predict(X_te_))\n",
    "    return {'Конфигурация': label, 'Accuracy': round(acc, 4),\n",
    "            'Компонент': X_tr_.shape[1], 'Время (с)': round(t1-t0, 1)}\n",
    "\n",
    "knn_params = grid_search.best_params_\n",
    "\n",
    "# 1.Baseline\n",
    "configs.append(eval_knn(X_tr, X_te, y_train, y_test, knn_params, 'Baseline (norm->const->PCA95)'))\n",
    "\n",
    "# 2.Без нормализации\n",
    "pca_raw = PCA(n_components=0.95, random_state=RANDOM_STATE)\n",
    "X_raw_filtered = X_train[:, const_mask].astype(float)\n",
    "X_raw_test_f   = X_test[:, const_mask].astype(float)\n",
    "X_raw_pca    = pca_raw.fit_transform(X_raw_filtered)\n",
    "X_raw_pca_te = pca_raw.transform(X_raw_test_f)\n",
    "configs.append(eval_knn(X_raw_pca, X_raw_pca_te, y_train, y_test,\n",
    "                         knn_params, 'Без нормализации'))\n",
    "\n",
    "# 3.PCA до нормализации\n",
    "pca_pre = PCA(n_components=0.95, random_state=RANDOM_STATE)\n",
    "X_pre_pca    = pca_pre.fit_transform(X_train_proc)\n",
    "X_pre_pca_te = pca_pre.transform(X_test_proc)\n",
    "scaler_post = MinMaxScaler()\n",
    "X_pre_norm    = scaler_post.fit_transform(X_pre_pca)\n",
    "X_pre_norm_te = scaler_post.transform(X_pre_pca_te)\n",
    "configs.append(eval_knn(X_pre_norm, X_pre_norm_te, y_train, y_test,\n",
    "                         knn_params, 'PCA до нормализации'))\n",
    "\n",
    "# 4.PCA 80%\n",
    "pca80 = PCA(n_components=0.80, random_state=RANDOM_STATE)\n",
    "X_80    = pca80.fit_transform(X_train_proc)\n",
    "X_80_te = pca80.transform(X_test_proc)\n",
    "configs.append(eval_knn(X_80, X_80_te, y_train, y_test, knn_params, 'PCA 80%'))\n",
    "\n",
    "# 5.PCA 99%\n",
    "pca99 = PCA(n_components=0.99, random_state=RANDOM_STATE)\n",
    "X_99    = pca99.fit_transform(X_train_proc)\n",
    "X_99_te = pca99.transform(X_test_proc)\n",
    "configs.append(eval_knn(X_99, X_99_te, y_train, y_test, knn_params, 'PCA 99%'))\n",
    "\n",
    "configs_df = pd.DataFrame(configs).sort_values('Accuracy', ascending=False)\n",
    "print(configs_df.to_string(index=False))"
   ]
  },
