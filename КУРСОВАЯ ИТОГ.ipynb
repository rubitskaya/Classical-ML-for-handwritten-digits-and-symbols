   "source": [
    "estimators = [\n",
    "    ('knn',  KNeighborsClassifier(**grid_search.best_params_, n_jobs=-1)),\n",
    "    ('rf',   RandomForestClassifier(n_estimators=100, max_depth=20,\n",
    "                                     random_state=RANDOM_STATE, n_jobs=-1)),\n",
    "    ('lr',   LogisticRegression(max_iter=1000, C=1.0,\n",
    "                                  random_state=RANDOM_STATE, n_jobs=-1)),\n",
    "]\n",
    "\n",
    "meta_lr = LogisticRegression(max_iter=500, C=1.0, random_state=RANDOM_STATE, n_jobs=-1)\n",
    "\n",
    "stacking = StackingClassifier(\n",
    "    estimators=estimators,\n",
    "    final_estimator=meta_lr,\n",
    "    cv=3, n_jobs=-1\n",
    ")\n",
    "\n",
    "t0 = time.time()\n",
    "stacking.fit(X_tr, y_train)\n",
    "t_stack = time.time() - t0\n",
    "\n",
    "y_pred_stack = stacking.predict(X_te)\n",
    "acc_stack = accuracy_score(y_test, y_pred_stack)\n",
    "f1_stack  = f1_score(y_test, y_pred_stack, average='macro')\n",
    "\n",
    "print(f\"Stacking: Accuracy={acc_stack:.4f}, F1-macro={f1_stack:.4f}, время={t_stack:.0f} с\")\n",
    "print(f\"Лучший kNN (base): Accuracy={best_acc:.4f}\")\n",
    "print(f\"Улучшение от стекинга: {(acc_stack - best_acc)*100:+.2f} pp\")"
   ]
  },
