   "source": [
    "### 5.1 Кластеризация"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 45,
   "id": "2038e558",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x400 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Наилучшее K по силуэту: 2\n"
     ]
    }
   ],
   "source": [
    "np.random.seed(42)\n",
    "sample_idx = np.random.choice(X_train_proc.shape[0], 3000, replace=False)\n",
    "X_sample = X_train_proc[sample_idx]\n",
    "y_sample = y_train[sample_idx]\n",
    "\n",
    "inertias = []\n",
    "silhouettes = []\n",
    "K_range = range(2, 16)\n",
    "\n",
    "for k in K_range:\n",
    "    km = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
    "    km.fit(X_sample)\n",
    "    inertias.append(km.inertia_)\n",
    "    silhouettes.append(silhouette_score(X_sample, km.labels_))\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "axes[0].plot(K_range, inertias, 'bo-')\n",
    "axes[0].set_xlabel('Количество кластеров K')\n",
    "axes[0].set_ylabel('Инерция')\n",
    "axes[0].set_title('Метод локтя (K-means)')\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "axes[1].plot(K_range, silhouettes, 'ro-')\n",
    "axes[1].set_xlabel('Количество кластеров K')\n",
    "axes[1].set_ylabel('Коэффициент силуэта')\n",
    "axes[1].set_title('Коэффициент силуэта (K-means)')\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "best_k = K_range[np.argmax(silhouettes)]\n",
    "print(f\"Наилучшее K по силуэту: {best_k}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "98f3721d",
   "metadata": {},
   "source": [
    "На графике локтя выраженного перегиба нет, значит данные не разбиваются на четкие группы, на графике не видно 47 четких кластеров.\n",
    "\n",
    "Аналогично и с кластеризацией k-means: она не смогла выделить 47 классов, но мы видим, что наилучшее значение силуэта достигнуто при К=2, что приравнивается к разделению на буквы и цифры, что снова же подтверждает сложность задачи."
