    "test_images = {\n",
    "    'O.png': 'O',\n",
    "    '1.png': '1',\n",
    "    '3.png': '3',\n",
    "    'W.png': 'W',\n",
    "    'I.png': 'I',\n",
    "    '0.png': '0',\n",
    "    '4.png': '4',\n",
    "    'F.png': 'F'\n",
    "}\n",
    "\n",
    "def preprocess_custom_image(path):\n",
    "    img = Image.open(path).convert('L')\n",
    "    img = np.array(img)\n",
    "    #инвертируем, чтобы был белый символ на черном фоне\n",
    "    img = 255 - img\n",
    "    # обрезаем пустые края\n",
    "    rows = np.any(img > 30, axis=1)\n",
    "    cols = np.any(img > 30, axis=0)\n",
    "    rmin, rmax = np.where(rows)[0][[0, -1]]\n",
    "    cmin, cmax = np.where(cols)[0][[0, -1]]\n",
    "    img = img[rmin:rmax+1, cmin:cmax+1]\n",
    "    #делаем квадратным с отступом\n",
    "    size = max(img.shape)\n",
    "    pad = int(size * 0.15)\n",
    "    square = np.zeros((size + 2*pad, size + 2*pad), dtype=np.uint8)\n",
    "    r_off = pad + (size - img.shape[0]) // 2\n",
    "    c_off = pad + (size - img.shape[1]) // 2\n",
    "    square[r_off:r_off+img.shape[0], c_off:c_off+img.shape[1]] = img\n",
    "    pil_img = Image.fromarray(square).resize((28, 28), Image.LANCZOS)\n",
    "    img_normal = np.array(pil_img)  \n",
    "    #приводим к формату хранения для подачи в модель\n",
    "    img_emnist = np.rot90(img_normal, k=-1)\n",
    "    img_emnist = np.fliplr(img_emnist)\n",
    "    return img_normal, img_emnist\n",
    "\n",
    "fig, axes = plt.subplots(2, 8, figsize=(20, 6))\n",
    "\n",
    "for i, (fname, true_label) in enumerate(test_images.items()):\n",
    "    img_normal, img_emnist = preprocess_custom_image(fname)\n",
    "\n",
    "    #показываем как нарисовано\n",
    "    axes[0, i].imshow(img_normal, cmap='gray')\n",
    "    axes[0, i].set_title(f'Нарисовано: {true_label}')\n",
    "    axes[0, i].axis('off')\n",
    "\n",
    "    #подаем в модель\n",
    "    vec = img_emnist.flatten() / 255.0\n",
    "    vec_filtered = vec[const_mask]\n",
    "    vec_pca = pca.transform(vec_filtered.reshape(1, -1))\n",
    "\n",
    "    pred_label = stacking.predict(vec_pca)[0]\n",
    "    pred_symbol = label_map[pred_label]\n",
    "\n",
    "    #пример из датасета с предсказанным классом\n",
    "    idx_example = np.where(y_train == pred_label)[0][0]\n",
    "    img_example = X_train[idx_example].reshape(28, 28)\n",
    "    img_example = np.fliplr(np.rot90(img_example, k=-1))\n",
    "    axes[1, i].imshow(img_example, cmap='gray')\n",
    "\n",
    "    correct = pred_symbol == true_label\n",
    "    color = 'green' if correct else 'red'\n",
    "    axes[1, i].set_title(f'Предсказано: {pred_symbol}', color=color)\n",
    "    axes[1, i].axis('off')\n",
    "\n",
    "axes[0, 0].set_ylabel('Вход', fontsize=12)\n",
    "axes[1, 0].set_ylabel('Пример из датасета', fontsize=12)\n",
    "\n",
    "plt.suptitle('Тест модели на собственных изображениях')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "correct_count = 0\n",
    "for fname, true_label in test_images.items():\n",
    "    img_normal, img_emnist = preprocess_custom_image(fname)\n",
    "    vec = img_emnist.flatten() / 255.0\n",
    "    vec_filtered = vec[const_mask]\n",
    "    vec_pca = pca.transform(vec_filtered.reshape(1, -1))\n",
    "    pred_label = stacking.predict(vec_pca)[0]\n",
    "    pred_symbol = label_map[pred_label]\n",
    "    correct = pred_symbol == true_label\n",
    "    if correct:\n",
    "        correct_count += 1\n",
    "    status = 'верно' if correct else 'неверно'\n",
    "    print(f'{fname}: истинный={true_label}, предсказано={pred_symbol} -> {status}')\n",
    "\n",
    "print(f'\\nИтого верно: {correct_count} из {len(test_images)}')"
   ]
