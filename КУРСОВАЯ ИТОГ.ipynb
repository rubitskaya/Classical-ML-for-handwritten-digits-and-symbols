   ]
  },
  {
   "cell_type": "code",
   "execution_count": 38,
   "id": "c3193079",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "До нормализации:  min=0, max=255\n",
      "После нормализации: min=0.000, max=1.000\n",
