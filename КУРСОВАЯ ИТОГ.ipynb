     ]
    }
   ],
   "source": [
    "X_train_norm = X_train / 255.0\n",
    "X_test_norm  = X_test  / 255.0\n",
    "\n",
    "stds_norm = X_train_norm.std(axis=0)\n",
    "const_mask = stds_norm > 0.01\n",
    "\n",
    "X_train_proc = X_train_norm[:, const_mask]\n",
    "X_test_proc  = X_test_norm[:, const_mask]\n",
    "\n",
    "print(f\"До нормализации:  min={X_train.min()}, max={X_train.max()}\")\n",
    "print(f\"После нормализации: min={X_train_norm.min():.3f}, max={X_train_norm.max():.3f}\")\n",
    "print(f\"Признаков до удаления константных: {X_train_norm.shape[1]}\")\n",
    "print(f\"Признаков после удаления: {X_train_proc.shape[1]}\")\n",
    "print(f\"Удалено константных: {X_train_norm.shape[1] - X_train_proc.shape[1]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2a8dd7bd",
   "metadata": {},
   "source": [
    "Привели значения пикселей к диапазону [0,1], для более корректной работы алгоритмов и удалили константные признаки, которые ни на что не влияют."
