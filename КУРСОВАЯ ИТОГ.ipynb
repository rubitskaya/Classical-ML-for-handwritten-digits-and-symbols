    "train_sizes, train_scores, val_scores = learning_curve(\n",
    "    best_single, X_tr, y_train,\n",
    "    train_sizes=np.linspace(0.1, 1.0, 8),\n",
    "    cv=3, scoring='accuracy',\n",
    "    n_jobs=-1, random_state=RANDOM_STATE\n",
    ")\n",
    "\n",
    "plt.figure(figsize=(8, 5))\n",
    "plt.plot(train_sizes, train_scores.mean(axis=1), label='Train', color='steelblue')\n",
    "plt.fill_between(train_sizes,\n",
    "                  train_scores.mean(axis=1) - train_scores.std(axis=1),\n",
    "                  train_scores.mean(axis=1) + train_scores.std(axis=1), alpha=0.2)\n",
    "plt.plot(train_sizes, val_scores.mean(axis=1), label='Validation', color='coral')\n",
    "plt.fill_between(train_sizes,\n",
    "                  val_scores.mean(axis=1) - val_scores.std(axis=1),\n",
    "                  val_scores.mean(axis=1) + val_scores.std(axis=1), alpha=0.2)\n",
    "plt.xlabel('Размер обучающей выборки')\n",
    "plt.ylabel('Accuracy')\n",
    "plt.title(f'Кривые обучения - kNN (лучшие параметры)')\n",
    "plt.legend()\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
