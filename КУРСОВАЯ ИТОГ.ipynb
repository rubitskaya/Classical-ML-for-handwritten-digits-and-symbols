    "def show_grid(X, y, label_map, indices=None, num=6, title=\"\"):\n",
    "    if indices is None:\n",
    "        indices = range(num)\n",
    "    plt.figure(figsize=(10, 4))\n",
    "    for i, idx in enumerate(list(indices)[:num]):\n",
    "        img = X[idx].reshape(28, 28)\n",
    "        #отражаем и поворачиваем\n",
    "        img = np.fliplr(np.rot90(img, k=-1))\n",
    "        plt.subplot(2, 3, i + 1)\n",
    "        plt.imshow(img, cmap='gray')\n",
    "        plt.title(f\"{label_map[int(y[idx])]}\")\n",
    "        plt.axis('off')\n",
    "    if title:\n",
    "        plt.suptitle(title)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "show_grid(X_train, y_train, label_map, title=\"Примеры изображений EMNIST Balanced\")"
